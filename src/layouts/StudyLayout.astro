---
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
}
const { title = 'CCA-F Field Manual' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=VT323&family=JetBrains+Mono:wght@400;700;800&display=swap"
    rel="stylesheet"
  />
  <ClientRouter />
</head>
<body>
  <div class="app-shell">
    <Sidebar />
    <main class="content" id="content">
      <div class="content-inner">
        <slot />
      </div>
    </main>
  </div>
</body>
</html>

<style is:global>
  /* ============================================================
     THEME TOKENS  (scoped under [data-theme] for Path C plumbing)
     Dark is the only theme defined in the MVP. Light tokens are
     deferred to phase 2; the toggle is wired and will flip the
     attribute, but light values are intentionally not yet set.
     ============================================================ */
  [data-theme='dark'] {
    --bg: #0a0612;
    --bg-deep: #060410;
    --panel: #120a24;
    --panel-line: #2a1a4a;
    --neon-magenta: #ff2bd6;
    --neon-cyan: #19f0ff;
    --neon-lime: #9dff3c;
    --neon-amber: #ffb627;
    --text: #d7c9f5;
    --text-dim: #7e6fa8;
    --danger: #ff3b6b;
    --mono: 'JetBrains Mono', monospace;
    --crt: 'VT323', monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg-deep);
    color: var(--text);
    font-family: var(--mono);
    line-height: 1.6;
    position: relative;
    min-height: 100vh;
  }

  /* scanline + grain atmosphere (shared, was duplicated per page) */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0) 0px,
      rgba(0, 0, 0, 0) 2px,
      rgba(0, 0, 0, 0.18) 3px,
      rgba(0, 0, 0, 0) 4px
    );
    mix-blend-mode: multiply;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9998;
    background: radial-gradient(ellipse at 50% 0%, rgba(255, 43, 214, 0.08), transparent 55%),
      radial-gradient(ellipse at 80% 90%, rgba(25, 240, 255, 0.06), transparent 50%);
  }

  /* ============================================================
     APP SHELL: sidebar + content
     ============================================================ */
  .app-shell {
    display: grid;
    grid-template-columns: 320px 1fr;
    min-height: 100vh;
  }

  .content {
    min-width: 0; /* allow inner content to scroll horizontally if needed */
    position: relative;
    z-index: 1;
  }
  .content-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 120px;
  }

  /* ============================================================
     SIDEBAR
     ============================================================ */
  .sidebar {
    background: var(--bg-deep);
    border-right: 1px solid var(--panel-line);
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    z-index: 2;
    display: flex;
    flex-direction: column;
  }
  .sidebar-head {
    padding: 22px 20px 16px;
    border-bottom: 1px solid var(--panel-line);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 4px 10px;
  }
  .brand {
    font-family: var(--crt);
    font-size: 2rem;
    color: var(--neon-cyan);
    letter-spacing: 3px;
    text-shadow: 0 0 12px rgba(25, 240, 255, 0.6);
    line-height: 1;
  }
  .brand-sub {
    font-family: var(--crt);
    font-size: 1.1rem;
    color: var(--text-dim);
    letter-spacing: 4px;
    grid-column: 1;
  }
  .theme-toggle {
    grid-row: 1 / 3;
    grid-column: 2;
    background: transparent;
    border: 1px solid var(--panel-line);
    color: var(--neon-amber);
    font-size: 1.2rem;
    width: 38px;
    height: 38px;
    cursor: pointer;
    transition: 0.18s;
    align-self: center;
  }
  .theme-toggle:hover {
    border-color: var(--neon-amber);
    box-shadow: 0 0 14px rgba(255, 182, 39, 0.3);
  }

  /* meta nav: loose top-level pages shown above the domain list */
  .meta-nav {
    padding: 10px 0 8px;
    border-bottom: 1px solid var(--panel-line);
  }
  .meta-link {
    padding: 8px 18px;
    font-size: 0.82rem;
    color: var(--text);
  }
  .meta-link:hover {
    color: var(--neon-cyan);
    background: rgba(25, 240, 255, 0.05);
  }
  .meta-link.active {
    color: var(--neon-cyan);
    border-left-color: var(--neon-cyan);
    background: rgba(25, 240, 255, 0.08);
    box-shadow: inset 0 0 18px rgba(25, 240, 255, 0.06);
    text-shadow: 0 0 8px rgba(25, 240, 255, 0.4);
  }

  .nav { flex: 1; padding: 10px 0 20px; }

  /* domain */
  .domain { border-bottom: 1px solid rgba(42, 26, 74, 0.5); }
  .domain-head,
  .task-head {
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text);
    font-family: var(--mono);
    transition: 0.15s;
  }
  .domain-head {
    padding: 14px 18px;
    flex-wrap: wrap;
  }
  .domain-head:hover { background: rgba(25, 240, 255, 0.05); }
  .domain-id {
    font-family: var(--crt);
    font-size: 1.3rem;
    color: var(--neon-cyan);
    letter-spacing: 1px;
  }
  .domain-title {
    font-size: 0.8rem;
    color: var(--text);
    flex: 1;
    min-width: 0;
  }
  .weight {
    font-family: var(--crt);
    font-size: 1.1rem;
    color: var(--neon-amber);
    text-shadow: 0 0 8px rgba(255, 182, 39, 0.4);
  }

  /* collapse mechanics: bodies hidden until parent .open */
  .domain-body,
  .task-body { display: none; }
  .domain.open > .domain-body { display: block; }
  .task.open > .task-body { display: block; }

  .chev {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--text-dim);
    transition: transform 0.2s;
    width: 12px;
  }
  .domain.open > .domain-head .chev,
  .task.open > .task-head .chev {
    transform: rotate(90deg);
    color: var(--neon-lime);
  }

  /* task */
  .task { border-top: 1px solid rgba(42, 26, 74, 0.4); }
  .task-head {
    padding: 10px 18px 10px 26px;
  }
  .task-head:hover { background: rgba(157, 255, 60, 0.05); }
  .task-id {
    font-family: var(--crt);
    font-size: 1.1rem;
    color: var(--neon-lime);
    letter-spacing: 1px;
  }
  .task-title {
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  /* page links */
  .page-link {
    display: block;
    padding: 8px 18px 8px 48px;
    font-size: 0.8rem;
    color: var(--text-dim);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: 0.15s;
  }
  .page-link:hover {
    color: var(--text);
    background: rgba(255, 43, 214, 0.05);
  }
  .page-link.active {
    color: var(--neon-lime);
    border-left-color: var(--neon-lime);
    background: rgba(157, 255, 60, 0.08);
    box-shadow: inset 0 0 18px rgba(157, 255, 60, 0.06);
    text-shadow: 0 0 8px rgba(157, 255, 60, 0.4);
  }
  .empty {
    padding: 8px 18px 8px 48px;
    font-size: 0.74rem;
    color: var(--text-dim);
    font-style: italic;
    opacity: 0.6;
  }

  .sidebar-foot {
    padding: 14px 20px;
    border-top: 1px solid var(--panel-line);
    font-size: 0.68rem;
    color: var(--text-dim);
    letter-spacing: 1px;
  }

  /* ============================================================
     RESPONSIVE: stack sidebar on top on narrow screens (basic MVP)
     ============================================================ */
  @media (max-width: 820px) {
    .app-shell { grid-template-columns: 1fr; }
    .sidebar {
      position: relative;
      height: auto;
      max-height: 50vh;
      border-right: none;
      border-bottom: 1px solid var(--panel-line);
    }
  }

  /* shared blinking cursor used by page footers/headers */
  .blink {
    display: inline-block;
    width: 0.6em;
    height: 1.1em;
    background: var(--neon-lime);
    margin-left: 6px;
    vertical-align: -2px;
    box-shadow: 0 0 10px var(--neon-lime);
    animation: blink 1.1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
</style>
