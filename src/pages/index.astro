---
import StudyLayout from '../layouts/StudyLayout.astro';
---

<StudyLayout title="CCA-F Field Manual">
  <div class="home">
    <div class="home-kicker">// CCA-F FIELD MANUAL</div>
    <h1 class="home-h1">Pick a Page</h1>
    <p class="home-lead">
      Use the sidebar to navigate. Each <span class="hl-cy">domain</span> expands into its
      <span class="hl-lm">task statements</span>, and each task holds the
      study pages built for it. Domain 1, Task 1.1 is populated; the rest are on the way.
    </p>

    <div class="home-grid">
      <div class="home-card">
        <div class="hc-id">D1</div>
        <div class="hc-title">Agentic Architecture &amp; Orchestration</div>
        <div class="hc-weight">27%</div>
        <div class="hc-note">Start with Task 1.1: the agentic loop, from setup to anti-patterns.</div>
      </div>
      <div class="home-card dim">
        <div class="hc-id">D2</div>
        <div class="hc-title">Tool Design &amp; MCP Integration</div>
        <div class="hc-weight">18%</div>
        <div class="hc-note">Coming soon.</div>
      </div>
      <div class="home-card dim">
        <div class="hc-id">D3</div>
        <div class="hc-title">Claude Code Configuration &amp; Workflows</div>
        <div class="hc-weight">20%</div>
        <div class="hc-note">Coming soon.</div>
      </div>
      <div class="home-card dim">
        <div class="hc-id">D4</div>
        <div class="hc-title">Prompt Engineering &amp; Structured Output</div>
        <div class="hc-weight">20%</div>
        <div class="hc-note">Coming soon.</div>
      </div>
      <div class="home-card dim">
        <div class="hc-id">D5</div>
        <div class="hc-title">Context Management &amp; Reliability</div>
        <div class="hc-weight">15%</div>
        <div class="hc-note">Coming soon.</div>
      </div>
    </div>

    <div class="home-foot">study artifact only &middot; no code execution<span class="blink"></span></div>
  </div>
</StudyLayout>

<style>
  .home { padding-top: 80px; }
  .home-kicker {
    font-family: var(--crt);
    font-size: 1.5rem;
    color: var(--neon-cyan);
    letter-spacing: 4px;
    text-shadow: 0 0 12px rgba(25, 240, 255, 0.6);
    margin-bottom: 10px;
  }
  .home-h1 {
    font-family: var(--crt);
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.92;
    color: var(--neon-lime);
    text-shadow: 0 0 18px rgba(157, 255, 60, 0.6), 4px 4px 0 rgba(25, 240, 255, 0.3);
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .home-lead {
    margin: 22px 0 40px;
    max-width: 680px;
    color: var(--text-dim);
    font-size: 0.95rem;
  }
  .hl-cy { color: var(--neon-cyan); }
  .hl-lm { color: var(--neon-lime); }

  .home-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }
  .home-card {
    border: 1px solid var(--panel-line);
    background: var(--panel);
    padding: 22px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    gap: 4px 12px;
    align-items: center;
    transition: 0.2s;
  }
  .home-card:not(.dim):hover {
    border-color: var(--neon-cyan);
    box-shadow: 0 0 22px rgba(25, 240, 255, 0.15);
    transform: translateY(-3px);
  }
  .home-card.dim { opacity: 0.55; }
  .hc-id {
    font-family: var(--crt);
    font-size: 1.8rem;
    color: var(--neon-cyan);
    grid-row: 1 / 3;
    text-shadow: 0 0 10px rgba(25, 240, 255, 0.4);
  }
  .hc-title { font-size: 0.92rem; color: #fff; }
  .hc-weight {
    font-family: var(--crt);
    font-size: 1.3rem;
    color: var(--neon-amber);
    text-shadow: 0 0 8px rgba(255, 182, 39, 0.4);
  }
  .hc-note {
    grid-column: 2 / 4;
    font-size: 0.78rem;
    color: var(--text-dim);
  }
  .home-foot {
    margin-top: 50px;
    padding-top: 20px;
    border-top: 1px solid var(--panel-line);
    color: var(--text-dim);
    font-size: 0.78rem;
    letter-spacing: 1px;
  }
</style>
