    position:relative;
  }
  .alt-tag{
    position:absolute;top:-11px;left:24px;background:var(--bg-deep);padding:0 10px;
    font-family:var(--crt);font-size:1.2rem;color:var(--neon-magenta);letter-spacing:3px;
    text-shadow:0 0 10px rgba(255,43,214,0.7);
  }
  .alt-h3{font-family:var(--crt);font-size:1.5rem;color:#fff;letter-spacing:1px;margin:0 0 10px;text-transform:uppercase;}
  .alt-h3 code{font-family:var(--mono);font-size:1.1rem;background:rgba(255,43,214,0.1);border:1px solid rgba(255,43,214,0.3);padding:0 6px;}
  .alt-lead{color:var(--text-dim);font-size:0.92rem;line-height:1.55;max-width:720px;}
  .alt-lead a{color:var(--neon-magenta);border-bottom-color:var(--neon-magenta);}
  .alt-lead a:hover{text-shadow:0 0 8px rgba(255,43,214,0.6);}
  .alt-lead code{font-family:var(--mono);color:var(--neon-magenta);font-size:0.84rem;}
  .alt-head{
    margin:0 0 14px;padding:10px 14px;
    background:rgba(255,43,214,0.06);border:1px solid rgba(255,43,214,0.3);
    font-size:0.84rem;color:var(--text);line-height:1.55;
  }
  .alt-head b{color:var(--neon-magenta);}
  .alt-head code{font-family:var(--mono);background:rgba(255,43,214,0.1);border:1px solid rgba(255,43,214,0.25);padding:1px 6px;font-size:0.76rem;color:var(--text);word-break:break-all;}
  .alt-sub{
    font-family:var(--crt);font-size:1.2rem;color:var(--neon-cyan);letter-spacing:2px;
    margin:24px 0 6px;text-transform:uppercase;
    display:flex;align-items:baseline;gap:12px;flex-wrap:wrap;
  }
  .alt-note{font-family:var(--mono);font-size:0.72rem;color:var(--text-dim);letter-spacing:0;text-transform:none;font-weight:400;}
  .alt-foot{margin-top:18px;padding-top:14px;border-top:1px dashed rgba(255,43,214,0.3);font-size:0.84rem;color:var(--text-dim);line-height:1.55;}
  .alt-foot b{color:var(--neon-magenta);}
  .alt-foot code{font-family:var(--mono);background:rgba(255,43,214,0.08);border:1px solid rgba(255,43,214,0.2);padding:1px 6px;font-size:0.78rem;color:var(--text);}

  /* DONE */
  .done-box{
    margin-top:60px;border:1px solid var(--neon-magenta);
    background:linear-gradient(180deg,rgba(255,43,214,0.05),transparent);
    padding:28px 30px;box-shadow:0 0 26px rgba(255,43,214,0.1);
  }
  .done-box h3{font-family:var(--crt);font-size:1.7rem;color:var(--neon-magenta);letter-spacing:2px;text-shadow:0 0 10px rgba(255,43,214,0.5);margin-bottom:14px;}
  .done-box ul{list-style:none;}
  .done-box li{padding-left:26px;position:relative;margin:12px 0;font-size:0.9rem;}
  .done-box li::before{content:"▸";position:absolute;left:0;color:var(--neon-magenta);font-size:1.1rem;}
  .done-box b{color:var(--neon-cyan);}

  footer{margin-top:70px;padding-top:24px;border-top:1px solid var(--panel-line);color:var(--text-dim);font-size:0.78rem;text-align:center;letter-spacing:1px;}
</style>

<script is:inline>
(function(){
  // OS tab switching, scoped per group so each section switches independently.
  document.querySelectorAll('.os-tabs').forEach(function(tabs){
    var group = tabs.getAttribute('data-group');
    tabs.querySelectorAll('.os-tab').forEach(function(btn){
      btn.addEventListener('click', function(){
        var os = btn.getAttribute('data-os');
        // toggle buttons in this group
        tabs.querySelectorAll('.os-tab').forEach(function(b){ b.classList.toggle('active', b===btn); });
        // toggle panels in this group
        document.querySelectorAll('.os-panel[data-group="'+group+'"]').forEach(function(p){
          p.classList.toggle('active', p.getAttribute('data-os')===os);
        });
      });
    });
  });
})();
</script>
