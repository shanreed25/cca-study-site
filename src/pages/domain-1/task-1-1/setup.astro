  .dot{width:11px;height:11px;border-radius:50%;}
  .dot.r{background:var(--danger);box-shadow:0 0 8px var(--danger);}
  .dot.y{background:var(--neon-amber);box-shadow:0 0 8px var(--neon-amber);}
  .dot.g{background:var(--neon-lime);box-shadow:0 0 8px var(--neon-lime);}
  .code-bar .fname{margin-left:8px;font-size:0.76rem;color:var(--text-dim);letter-spacing:1px;}
  .code pre{margin:0;padding:18px 20px;overflow-x:auto;font-size:0.84rem;line-height:1.6;tab-size:4;}
  .code pre code{font-family:var(--mono);color:var(--text);}
  .prompt{color:var(--neon-lime);} /* shell $ */
  .k{color:var(--neon-magenta);} .s{color:var(--neon-lime);} .c{color:var(--text-dim);font-style:italic;}
  .f{color:var(--neon-cyan);} .n{color:var(--neon-amber);}

  /* OS TABS */
  .os-tabs{display:flex;gap:0;margin-top:14px;border-bottom:1px solid var(--panel-line);}
  .os-tab{
    font-family:var(--crt);font-size:1.25rem;letter-spacing:2px;padding:8px 22px;
    background:transparent;color:var(--text-dim);border:1px solid transparent;border-bottom:none;
    cursor:pointer;text-transform:uppercase;transition:.15s;
  }
  .os-tab:hover{color:var(--text);}
  .os-tab.active{color:var(--neon-cyan);border-color:var(--panel-line);background:var(--panel);text-shadow:0 0 8px rgba(25,240,255,0.5);position:relative;top:1px;}
  .os-panel{display:none;}
  .os-panel.active{display:block;}

  /* RUN OUTPUT */
  .output{
    border:1px solid var(--neon-lime);background:rgba(157,255,60,0.04);padding:16px 20px;margin:18px 0;
    box-shadow:inset 0 0 18px rgba(157,255,60,0.05);
  }
  .output .label{font-family:var(--crt);font-size:1.2rem;color:var(--neon-lime);letter-spacing:2px;text-shadow:0 0 10px rgba(157,255,60,0.5);margin-bottom:6px;}
  .output pre{font-size:0.84rem;color:var(--text);white-space:pre-wrap;}

  /* CALLOUT (security) */
  .warn{border:1px solid var(--neon-amber);background:linear-gradient(180deg,rgba(255,182,39,0.06),transparent);padding:14px 18px;margin:16px 0;font-size:0.86rem;}
  .warn b{color:var(--neon-amber);}

  /* CONDITIONAL NOTE (only-if-you-took-the-.env-path, magenta-themed) */
  .dotenv-note{
    border:1px dashed var(--neon-magenta);
    background:linear-gradient(180deg,rgba(255,43,214,0.04),transparent);
    padding:14px 18px;margin:20px 0;font-size:0.88rem;color:var(--text-dim);
  }
  .dotenv-note p{margin:0 0 10px;font-size:0.88rem;}
  .dotenv-note b{color:var(--text);}

  /* TWO-PATH LAYOUT (side-by-side venv + pip and uv boxes) */
  .paths-intro{
    margin:48px 0 18px;padding:14px 18px;
    border-top:1px dashed var(--panel-line);border-bottom:1px dashed var(--panel-line);
    font-size:0.92rem;color:var(--text-dim);line-height:1.55;
  }
  .paths-intro p{
    max-width:760px;margin:0 auto;
    text-align:left;            /* left-aligned text inside a centered block — wraps cleanly without center-induced raggedness */
  }
  .paths-intro strong{font-family:var(--crt);font-size:1.05rem;letter-spacing:3px;margin-right:6px;}
  .paths-intro em{font-style:italic;color:var(--text);}
  .paths-intro b{font-weight:700;}
  .paths{
    display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:stretch;margin:0 0 48px;
  }
  /* override the boxes' own outer margin while inside the grid */
  .paths > .path,
  .paths > .alt{margin:0;}
  /* stack vertically when the viewport (or content column) gets too narrow */
  @media (max-width:1100px){
    .paths{grid-template-columns:1fr;}
  }

  /* CALLOUT (venv + pip path — wraps Steps 3 and 4) */
  .path{
    margin:48px 0;border:1px solid var(--neon-cyan);
    background:linear-gradient(180deg,rgba(25,240,255,0.04),rgba(25,240,255,0.01));
    padding:8px 30px 28px;box-shadow:0 0 26px rgba(25,240,255,0.08),inset 0 0 30px rgba(25,240,255,0.025);
    position:relative;
  }
  .path-tag{
    position:absolute;top:-11px;left:24px;background:var(--bg-deep);padding:0 10px;
    font-family:var(--crt);font-size:1.2rem;color:var(--neon-cyan);letter-spacing:3px;
    text-shadow:0 0 10px rgba(25,240,255,0.7);
  }
  /* nested first .step gets no dashed top border or oversize margin */
  .path > .step:first-of-type{border-top:none;margin-top:18px;padding-top:0;}

  /* Sub-steps (03, 04) INSIDE a .path or .alt box */
  .path-step{margin-top:8px;}
  .path-step + .path-step{margin-top:28px;padding-top:24px;border-top:1px dashed var(--panel-line);}
  .path-step-head{display:flex;align-items:baseline;gap:14px;flex-wrap:wrap;margin-bottom:8px;}
  .path-step-head .step-num{font-family:var(--crt);font-size:2rem;color:var(--neon-magenta);text-shadow:0 0 12px rgba(255,43,214,0.55);line-height:1;}
  .path .path-step-head .step-num{color:var(--neon-cyan);text-shadow:0 0 12px rgba(25,240,255,0.55);}
  .path-step-head h3{font-family:var(--crt);font-size:1.4rem;color:var(--text);text-transform:uppercase;letter-spacing:2px;line-height:1;margin:0;}

  /* CALLOUT (modern alternative — uv) */
  .alt{
    margin:48px 0;border:1px solid var(--neon-magenta);
    background:linear-gradient(180deg,rgba(255,43,214,0.06),rgba(255,43,214,0.01));
