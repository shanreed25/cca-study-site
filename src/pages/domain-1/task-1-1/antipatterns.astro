  .family{
    margin-top:14px;display:inline-block;font-family:var(--crt);font-size:1.1rem;letter-spacing:1px;
    color:var(--neon-magenta);border:1px solid var(--neon-magenta);padding:4px 12px;
    text-shadow:0 0 8px rgba(255,43,214,0.4);
  }
  .family span{color:var(--text-dim);text-shadow:none;}

  /* THE TELL CHEAT SHEET */
  section.tells{padding:64px 0 0;border-top:1px dashed var(--panel-line);margin-top:60px;}
  .sec-num{font-family:var(--crt);font-size:1.4rem;color:var(--neon-lime);letter-spacing:3px;text-shadow:0 0 10px rgba(157,255,60,0.5);}
  h2{font-family:var(--crt);font-size:clamp(1.8rem,4vw,2.8rem);color:var(--text);text-transform:uppercase;letter-spacing:1px;margin:6px 0 18px;line-height:1;}
