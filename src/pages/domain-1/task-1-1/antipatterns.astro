  .glow-cy{color:var(--neon-cyan);} .glow-lm{color:var(--neon-lime);} .glow-am{color:var(--neon-amber);} .glow-dg{color:var(--danger);}
</style>

<script is:inline>
(function(){
  // Correct answer per card: card 1,2,3 are BROKEN (answer "no"); card 4 is CORRECT (answer "yes").
  var answers = { "1":"no", "2":"no", "3":"no", "4":"yes" };

  document.querySelectorAll('.gate').forEach(function(gate){
    var card = gate.getAttribute('data-card');
    var correct = answers[card];
    var feedback = gate.querySelector('.gate-feedback');
    var verdict = feedback.querySelector('.verdict');
    var reveal = gate.closest('.card-body').querySelector('.reveal');

    gate.querySelectorAll('.gate-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        var picked = btn.getAttribute('data-answer');
        var right = picked === correct;

        feedback.classList.remove('correct','wrong');
        feedback.classList.add('show', right ? 'correct' : 'wrong');

        if(right){
          verdict.textContent = card === "4"
            ? "✓ CORRECT, and you confirmed it instead of second-guessing."
            : "✓ CORRECT. You flagged the break.";
        } else {
          verdict.textContent = card === "4"
            ? "✗ WRONG. This one is actually correct, see why below."
            : "✗ WRONG. It looks fine, but it's broken, see why below.";
        }

        // reveal the explanation either way; the point is to commit first, then learn.
        reveal.classList.add('show');

        // lock buttons after answering
        gate.querySelectorAll('.gate-btn').forEach(function(b){
          b.style.opacity = (b===btn) ? "1" : "0.4";
          b.style.pointerEvents = "none";
        });
      });
    });
  });
})();
</script>
